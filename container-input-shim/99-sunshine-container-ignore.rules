# Ignore virtual input devices created inside containers.
#
# The LD_PRELOAD shim (libuinput_shim.so) tags every uinput/UHID device
# with phys="container-<CONTAINER_ID>".  These rules prevent the host
# desktop from consuming those devices, while leaving host-native devices
# (including host Steam's virtual gamepads) untouched.
#
# Install: sudo cp 99-sunshine-container-ignore.rules /etc/udev/rules.d/
#          sudo udevadm control --reload-rules

# Make libinput ignore container-tagged input devices
SUBSYSTEM=="input", ATTR{phys}=="container-*", ENV{LIBINPUT_IGNORE_DEVICE}="1"

# Prevent systemd-logind and other consumers from treating them as host input
SUBSYSTEM=="input", ATTR{phys}=="container-*", ENV{ID_INPUT}=""
SUBSYSTEM=="input", ATTR{phys}=="container-*", ENV{ID_INPUT_JOYSTICK}=""
SUBSYSTEM=="input", ATTR{phys}=="container-*", ENV{ID_INPUT_KEY}=""
SUBSYSTEM=="input", ATTR{phys}=="container-*", ENV{ID_INPUT_KEYBOARD}=""
SUBSYSTEM=="input", ATTR{phys}=="container-*", ENV{ID_INPUT_MOUSE}=""
SUBSYSTEM=="input", ATTR{phys}=="container-*", ENV{ID_INPUT_TOUCHPAD}=""
SUBSYSTEM=="input", ATTR{phys}=="container-*", ENV{ID_INPUT_TOUCHSCREEN}=""
SUBSYSTEM=="input", ATTR{phys}=="container-*", ENV{ID_INPUT_TABLET}=""
