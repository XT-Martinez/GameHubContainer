# Isolate virtual input devices created inside containers from the host desktop.
#
# The LD_PRELOAD shim (libuinput_shim.so) tags every uinput/UHID device
# with phys="container-<CONTAINER_ID>".  These rules assign container devices
# to a non-existent seat (seat9) and remove group-read permission.
#
# MODE=0600 is critical: HHD (Handheld Daemon) voluntarily skips devices
# without group-read (checks st_mode & S_IRGRP), which is the only way to
# hide devices from it in SteamOS/gamescope mode where seat-based filtering
# is not effective.
#
# For UHID devices (DualSense/DS5), the kernel doesn't propagate the phys
# field to sysfs, so we match by device name instead.
#
# Install: sudo cp 99-sunshine-container-ignore.rules /etc/udev/rules.d/
#          sudo udevadm control --reload-rules && sudo udevadm trigger

# Allow containers to create virtual input devices.
# In rootless podman, device permissions cannot be changed inside the container
# (kernel blocks chmod/setfacl/mknod on device nodes in user namespaces).
# Setting 0666 on the host means the container's non-root user can access it.
KERNEL=="uinput", SUBSYSTEM=="misc", MODE="0666"
KERNEL=="uhid", SUBSYSTEM=="misc", MODE="0666"

# ── uinput devices (phys-tagged by our shim) ─────────────────
# Match event/js nodes via parent phys (ATTRS with S), strip group-read
# to hide from HHD, and assign to non-existent seat9.
SUBSYSTEM=="input", KERNEL=="event*|js*", ATTRS{phys}=="container-*", MODE="0600", ENV{ID_SEAT}="seat9", ENV{LIBINPUT_IGNORE_DEVICE}="1"
KERNEL=="hidraw*", ATTRS{phys}=="container-*", MODE="0600", ENV{ID_SEAT}="seat9"

# ── UHID devices (kernel doesn't propagate phys, match by name) ──
# The shim prefixes UHID device names with "Container " so we can
# distinguish them from identical host Sunshine devices.
# Child input devices inherit the prefix (e.g., "Container ... Touchpad").
SUBSYSTEM=="input", KERNEL=="event*|js*", ATTRS{name}=="Container *", MODE="0600", ENV{ID_SEAT}="seat9", ENV{LIBINPUT_IGNORE_DEVICE}="1"
SUBSYSTEM=="hidraw", ATTRS{name}=="Container *", MODE="0600", ENV{ID_SEAT}="seat9"
