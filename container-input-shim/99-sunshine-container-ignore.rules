# Isolate virtual input devices created inside containers from the host desktop.
#
# The LD_PRELOAD shim (libuinput_shim.so) tags every uinput/UHID device
# with phys="container-<CONTAINER_ID>".  These rules assign container devices
# to a non-existent seat (seat9), preventing the host desktop, libinput,
# systemd-logind, and host Steam from consuming them — while leaving
# host-native devices (including host Steam's virtual gamepads) untouched.
#
# This approach mirrors the Wolf project's isolation strategy.
#
# Install: sudo cp 99-sunshine-container-ignore.rules /etc/udev/rules.d/
#          sudo udevadm control --reload-rules && sudo udevadm trigger

# Allow containers to create virtual input devices.
# In rootless podman, device permissions cannot be changed inside the container
# (kernel blocks chmod/setfacl/mknod on device nodes in user namespaces).
# Setting 0666 on the host means the container's non-root user can access it.
KERNEL=="uinput", SUBSYSTEM=="misc", MODE="0666"
KERNEL=="uhid", SUBSYSTEM=="misc", MODE="0666"

# Assign container-tagged input devices to seat9 (non-existent seat).
# This hides them from logind (seat0), libinput, and the host desktop.
SUBSYSTEMS=="input", ATTR{phys}=="container-*", MODE="0660", GROUP="input", ENV{ID_SEAT}="seat9"

# Also handle hidraw devices from container UHID (DualSense passthrough)
KERNEL=="hidraw*", ATTRS{phys}=="container-*", MODE="0660", GROUP="input", ENV{ID_SEAT}="seat9"

# Make libinput explicitly ignore container devices (belt-and-suspenders)
SUBSYSTEM=="input", ATTR{phys}=="container-*", ENV{LIBINPUT_IGNORE_DEVICE}="1"
